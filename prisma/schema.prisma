generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Draw {
  id          Int      @id @default(autoincrement())
  round       Int      @unique
  drawDate    DateTime @map("draw_date")
  n1          Int
  n2          Int
  n3          Int
  n4          Int
  n5          Int
  n6          Int
  bonus       Int
  totalPrize  BigInt?  @map("total_prize")
  firstPrize  BigInt?  @map("first_prize")
  winnerCount Int?     @map("winner_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("draws")
}

model GeneratedSet {
  id        Int      @id @default(autoincrement())
  strategy  String
  numbers   Int[]
  bonus     Int?
  metaJson  Json?    @map("meta_json")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("generated_sets")
}
