{
  "name": "lotto-web-service",
  "version": "1.0.0",
  "description": "과거 당첨 데이터 기반 로또 번호 추천 웹 서비스",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview:draw-sync": "tsx scripts/deploy-draw-sync.ts --preview",
    "deploy:draw-sync": "tsx scripts/deploy-draw-sync.ts",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "next lint",
    "test": "tsx --tsconfig tsconfig.test.json --test tests/all.test.ts",
    "firestore:draws:sync": "tsx scripts/firestore-draws.ts",
    "firestore:draws:seed": "tsx scripts/firestore-draws.ts --seed-all",
    "sync:draws": "tsx scripts/sync-draws.ts",
    "sync:draws:check": "tsx scripts/sync-draws.ts --dry-run",
    "sync:manual": "tsx scripts/sync-manual.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "chart.js": "^4.0.0",
    "firebase": "^12.11.0",
    "html-to-image": "^1.11.13",
    "next": "^16.2.2",
    "react": "^18.0.0",
    "react-chartjs-2": "^5.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.38.0"
  }
}
